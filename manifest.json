{
  "name": "Pimp my Website",
  "version": "1.0.0",
  "description": "Run custom scripts on specific websites—Tampermonkey-style, with per-site enable/disable.",
  "manifest_version": 3,
  "minimum_chrome_version": "120",
  "permissions": [
    "userScripts",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Pimp my Website"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  }
}
